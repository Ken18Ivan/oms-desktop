{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "moduleResolution": "bundler",
    "module": "ESNext",
    "target": "ES2022",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "types": ["node"],
    "lib": ["ES2022"],
    "noEmit": false,
    "outDir": "./out/main",
    "rootDir": "./main"
  },
  "include": ["main/**/*"],
  "exclude": ["node_modules", "renderer/**/*"]
}
